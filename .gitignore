# Composer dependencies
/vendor/
composer.lock

# Environment variables
.env
.env.local
.env.testing

# IDE-specific files (common ones)
.idea/         # JetBrains IDEs (PhpStorm, etc)
.vscode/       # VS Code (if team-wide settings are not shared)
*.iml          # Intellij/PhpStorm project files

# Build artifacts and temporary files
/build/
/cache/
/log/
*.log
*.sql          # Database dumps
*.sqlite
/tmp/

# OS and Editor generated files
.DS_Store      # macOS
Thumbs.db      # Windows
ehthumbs.db    # Windows
[Tt]humbs.db   # Windows

# PHP-specific
*.phar
*.phpcbf
